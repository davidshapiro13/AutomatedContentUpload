#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$REPO_ROOT"

alert() {
  /usr/bin/osascript -e "display alert \"AutoReel\" message \"$1\" as warning" >/dev/null 2>&1 || true
}

if [ ! -x ".venv/bin/streamlit" ]; then
  alert "Streamlit is not installed in .venv. Run: .venv/bin/pip install -r requirements.txt"
  exit 1
fi

if [ -f ".env" ]; then
  set -a
  # shellcheck disable=SC1091
  source ".env"
  set +a
fi

exec ".venv/bin/streamlit" run "uploader_app.py" --server.address localhost --server.port 8501
